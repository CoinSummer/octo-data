# DataHub Market 配置

# CoinGecko API Key (可选，有则用 Pro API 提高限额)
COINGECKO_API_KEY=

# 追踪的币种 (CoinGecko IDs，逗号分隔)
DATAHUB_COINS=bitcoin,ethereum,solana,hyperliquid,binancecoin,ripple,cardano,dogecoin,toncoin,avalanche-2,chainlink,sui,aave,pendle

# Chainbot API (推文 + 新闻)
# https://chainbot.io/my/profile 获取
CHAINBOT_API_KEY=

# Binance API (公告 WebSocket 需要)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 服务端口
DATAHUB_PORT=8420

# 数据库路径 (默认同目录)
# DATAHUB_DB_PATH=./datahub-market.db

# CORS 允许的来源 (逗号分隔，默认 *)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# 外部脚本目录 (可选 — Slack Bot、DeFi Monitor 等)
# DATAHUB_SCRIPTS_DIR=/path/to/scripts
